# Server-side secrets (Vercel env vars — NOT exposed to the browser)
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# For local dev: copy this file to `.env.local` and fill in values; run `vercel dev`.

# Google AI Studio API key — used by /api/optimize-prompt (Gemini 2.5 Flash)
# Get from https://aistudio.google.com/app/api-keys
GOOGLE_API_KEY=AIzaSy...

# fal.ai API key — used for Seedance, Veo, Kling, Hunyuan, Wan, LTX models.
# Get from https://fal.ai/dashboard/keys
FAL_KEY=

# MuApi API key — optional. Used for Sora 2, Veo 3, and 200+ other models via MuApi.
# Get from https://muapi.ai (kullanıcı dashboard'undan)
# Leave blank if you only use fal.ai models.
MUAPI_KEY=

# Replicate API key — optional. Used for SaaS-friendly open-source models:
# Wan 2.7, Wan 2.5 Fast, Mochi 1, LTX-2.
# Get from https://replicate.com/account/api-tokens
REPLICATE_TOKEN=r8_

# Optional: override the API base URL for the frontend.
# VITE_API_BASE=/api
